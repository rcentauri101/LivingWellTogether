---
interface Props {
  eyebrow: string;
  title: string;
  text: string;
}

const { eyebrow, title, text } = Astro.props;
---

<section class="hero panel">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero-text">{text}</p>
  </div>
  <div class="hero-stats">
    <div class="stat-card">
      <span class="stat-value">12</span>
      <span class="stat-label">weeks together</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">3</span>
      <span class="stat-label">meals each day</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">1</span>
      <span class="stat-label">shared goal</span>
    </div>
  </div>
</section>
